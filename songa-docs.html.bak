  <div class="breadcrumb"><a onclick="showPage('home',null)">Home</a> › Chapter 20</div>
  <div class="chapter-hero"><div class="chapter-tag">Chapter 20</div><h1>Settings</h1><p class="lead">Account management, platform personalisation, and system user administration for the Songa web application.</p></div>
  <div class="doc-body">
    <h2 class="section-h2">20.1 General Settings</h2>
    <div class="field-list">
      <div class="field-item"><div class="field-name">Account Settings</div><div class="field-desc">Update First Name, Last Name, and Email Address for the logged-in user's profile</div></div>
      <div class="field-item"><div class="field-name">Personalise Your Experience</div><div class="field-desc">Upload or delete the organisation logo shown in the top bar. Select a theme colour from seven preset options: teal (default), blue, pink, purple, brown, grey, black.</div></div>
    </div>
    <h2 class="section-h2">20.2 System Users</h2>

<figure class="doc-screenshot">
  <img src="img/page081_img238.jpeg" alt="Settings — System Users listing showing roles and hub access scope per user" loading="lazy">
  <figcaption>Settings — System Users listing showing roles and hub access scope per user</figcaption>
</figure>

    <p>Listing columns: First Name · Last Name · Email · Role (inline dropdown to change) · Hub Station (access scope). Filters: Hub Station, Role. An Export as CSV button is available.</p>
    <table class="doc-table">
      <tr><th>Role</th><th>Hub Access</th></tr>
      <tr><td>Super Admin</td><td>All Hub Stations — cannot be restricted</td></tr>
      <tr><td>Hub Manager</td><td>Limited to 1 Hub Station</td></tr>
      <tr><td>Fleet Manager</td><td>Can be assigned to multiple specific hubs</td></tr>
    </table>
    <div class="warn-box"><em>Invitation Expired</em> appears in red for accounts where the signup link was not acted upon in time. Roles are defined at Admin Panel level and cannot be created from within the Settings page.</div>
    <h3 class="section-h3">Create User — Form Fields</h3>
    <table class="doc-table">
      <tr><th>Field</th><th>Description</th></tr>
      <tr><td>First Name / Last Name</td><td>User's full name</td></tr>
      <tr><td>Email</td><td>Invitation sent to this address. OTP-based authentication — no password field required.</td></tr>
      <tr><td>Role</td><td>Selected from roles configured for this tenant (defined at Admin Panel level)</td></tr>
      <tr><td>Hub Station</td><td>One or more hub stations — dropdown supports multi-hub assignment for Fleet Managers</td></tr>
    </table>
  </div>
</div>

  </div><!-- /content -->
</div><!-- /main -->
</div><!-- /app -->
<script>
const pages={home:document.getElementById('page-home'),ch1:document.getElementById('page-ch1'),ch2:document.getElementById('page-ch2'),ch3:document.getElementById('page-ch3'),ch4:document.getElementById('page-ch4'),ch5:document.getElementById('page-ch5'),ch6:document.getElementById('page-ch6'),ch7:document.getElementById('page-ch7'),ch8:document.getElementById('page-ch8'),ch9:document.getElementById('page-ch9'),ch10:document.getElementById('page-ch10'),ch11:document.getElementById('page-ch11'),ch12:document.getElementById('page-ch12'),ch13:document.getElementById('page-ch13'),ch14:document.getElementById('page-ch14'),ch15:document.getElementById('page-ch15'),ch16:document.getElementById('page-ch16'),ch17:document.getElementById('page-ch17'),ch18:document.getElementById('page-ch18'),ch19:document.getElementById('page-ch19'),ch20:document.getElementById('page-ch20')};

function showPage(id,el){
  Object.values(pages).forEach(p=>p.classList.remove('active'));
  if(pages[id])pages[id].classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(el){el.classList.add('active');}
  else{const m=document.querySelector('.nav-item[data-page="'+id+'"]');if(m)m.classList.add('active');}
  window.scrollTo(0,0);
}

const searchIndex=[];
Object.entries(pages).forEach(([id,el])=>{
  if(id==='home')return;
  const title=el.querySelector('h1')?el.querySelector('h1').textContent:'';
  const chTag=el.querySelector('.chapter-tag')?el.querySelector('.chapter-tag').textContent:'';
  searchIndex.push({id,title,chTag,text:el.textContent});
});

function doSearch(q){
  if(!q||q.length<2)return[];
  const lq=q.toLowerCase();
  const results=[];
  searchIndex.forEach(item=>{
    const ti=item.title.toLowerCase().includes(lq);
    const tx=item.text.toLowerCase().indexOf(lq);
    if(ti||tx>=0){
      let preview='';
      if(tx>=0){const s=Math.max(0,tx-40);const e=Math.min(item.text.length,tx+90);preview='…'+item.text.substring(s,e).replace(/\s+/g,' ').trim()+'…';}
      results.push({id:item.id,title:item.title,chTag:item.chTag,preview});
    }
  });
  return results.slice(0,8);
}

const si=document.getElementById('searchInput');
const sr=document.getElementById('search-results');
si.addEventListener('input',function(){
  const q=this.value.trim();
  const res=doSearch(q);
  if(!q||q.length<2){sr.classList.remove('open');return;}
  if(res.length===0){sr.innerHTML='<div class="sr-empty">No results for "'+q+'"</div>';}
  else{sr.innerHTML=res.map(r=>'<div class="sr-item" onclick="showPage(\''+r.id+'\',null);sr.classList.remove(\'open\');si.value=\'\'"><div class="sr-item-chapter">'+r.chTag+'</div><div class="sr-item-title">'+r.title+'</div><div class="sr-item-preview">'+r.preview+'</div></div>').join('');}
  sr.classList.add('open');
});
document.addEventListener('click',function(e){if(!sr.contains(e.target)&&e.target!==si)sr.classList.remove('open');});

const ssi=document.getElementById('sidebarSearchInput');
ssi.addEventListener('input',function(){
  const q=this.value.trim().toLowerCase();
  document.querySelectorAll('.nav-item[data-page]').forEach(item=>{
    item.style.display=(!q||item.textContent.toLowerCase().includes(q))?'':'none';
  });
});

document.addEventListener('keydown',function(e){
  if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();si.focus();si.select();}
});
</script>
</body>
</html>
